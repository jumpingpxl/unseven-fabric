{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "unseven",
    "description": "This is an example description! Tell everyone what your mod is about!",
    "authors": [
        "JumpingPxl"
    ],
    "contact": {
        "sources": "https://github.com/jumpingpxl/unseven-fabric"
    },
    "icon": "assets/${mod_id}/icon.png",
    "environment": "client",
    "entrypoints": {
        "preLaunch": [
            "modularmodtemplate.runner.DevEnvironmentMixinApplier::apply"
        ],
        "client": [
            "dev.jumpingpxl.unseven.core.Unseven"
        ],
        "modmenu": [
            "dev.jumpingpxl.unseven.integration.modmenu.ModMenuIntegration"
        ]
    },
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "minecraft": "${minecraft_version}",
        "java": ">=${java_version}",
        "fabric-api": "*",
        "yet_another_config_lib_v3": "*"
    },
    "suggests": {
        "modmenu": "*"
    }
}
